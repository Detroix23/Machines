" default-simple.vimrc
" By Detroix23.
"
" Simple, basic Vim configuration.

" Set to only Vim.
set nocompatible
" Wrap beyond screen length
set wrap
" Enconding
set encoding=utf-8
" Line number
set number
" Rulers
set ruler
" Bottom bar
set laststatus=2
" Auto indent
set ai
" Search
set hlsearch
set incsearch

